---
interface Props {
  title?: string;
  description?: string;
  ogType?: string;
  activeNav?: string;
}

const siteName = "tmpfs /home/stan";
const siteUrl = "https://blog.angeloff.name";
const siteDescription =
  "Stan Angeloff's blog, a collection of thoughts, rants & research";
const {
  title,
  description = siteDescription,
  ogType = "website",
  activeNav,
} = Astro.props;
const pageTitle = title ? `${title} · ${siteName}` : siteName;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogTitle = title || siteName;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Stan Angeloff" />
    <meta name="fediverse:creator" content="@stanangeloff@mastodon.social" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:site_name" content={siteName} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:type" content={ogType} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@StanAngeloff" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />

    <link
      rel="alternate"
      type="application/atom+xml"
      title={siteName}
      href="/atom.xml"
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteName}
      href="/rss.xml"
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Blog",
        name: siteName,
        description: siteDescription,
        url: siteUrl,
        author: {
          "@type": "Person",
          name: "Stan Angeloff",
          url: `${siteUrl}/about/`,
          sameAs: [
            "https://github.com/StanAngeloff",
            "https://mastodon.social/@stanangeloff",
            "https://www.linkedin.com/in/stanangeloff/",
            "https://x.com/StanAngeloff",
          ],
        },
      })}
    />
  </head>
  <body>
    <div class="col">
      <header class="site-header">
        <a class="brand" href="/"
          ><span class="prompt">~ </span>tmpfs /home/stan</a
        >
        <nav>
          <a href="/" aria-current={activeNav === "blog" ? "page" : undefined}
            >Blog</a
          >
          <span class="sep">&middot;</span>
          <a
            href="/about/"
            aria-current={activeNav === "about" ? "page" : undefined}>About</a
          >
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <span class="rule" aria-hidden="true"
          >━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━</span
        >
        <nav class="links" aria-label="Social links">
          <a href="https://github.com/StanAngeloff">GitHub</a><span class="sep"
            >&middot;</span
          ><a href="https://news.ycombinator.com/user?id=StanAngeloff"
            >Hacker&nbsp;News</a
          ><span class="sep">&middot;</span><a
            href="https://mastodon.social/@stanangeloff"
            rel="me">Mastodon</a
          ><span class="sep">&middot;</span><a
            href="https://www.linkedin.com/in/stanangeloff/">LinkedIn</a
          ><span class="sep">&middot;</span><a href="https://x.com/StanAngeloff"
            >X</a
          >
        </nav>
        <small class="copy">
          &copy; 2009&ndash;{new Date().getFullYear()} Stan Angeloff.<br />
          Posts and source code are published under the MIT licence.<span
            class="ornament"
          >
            &sect;</span
          >
        </small>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @import "../styles/theme.css";
</style>
