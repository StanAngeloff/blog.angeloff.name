---
import { getCollection, render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";
import NoteLayout from "../../layouts/NoteLayout.astro";
import fs from "node:fs";
import path from "node:path";

function postUrl(post: { id: string; data: { date: Date } }) {
  const date = post.data.date;
  const y = String(date.getUTCFullYear());
  const m = String(date.getUTCMonth() + 1).padStart(2, "0");
  const d = String(date.getUTCDate()).padStart(2, "0");
  return `/post/${y}/${m}/${d}/${post.id.slice(11)}/`;
}

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const notes = posts
    .filter((p) => p.data.type === "note")
    .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

  return posts.map((post) => {
    const date = post.data.date;
    const y = String(date.getUTCFullYear());
    const m = String(date.getUTCMonth() + 1).padStart(2, "0");
    const d = String(date.getUTCDate()).padStart(2, "0");
    const titleSlug = post.id.slice(11);

    let prevNote = null;
    let nextNote = null;
    if (post.data.type === "note") {
      const idx = notes.findIndex((n) => n.id === post.id);
      if (idx > 0) {
        prevNote = { url: postUrl(notes[idx - 1]), title: notes[idx - 1].data.title };
      }
      if (idx < notes.length - 1) {
        nextNote = { url: postUrl(notes[idx + 1]), title: notes[idx + 1].data.title };
      }
    }

    return {
      params: { slug: `${y}/${m}/${d}/${titleSlug}` },
      props: { post, prevNote, nextNote },
    };
  });
}

function extractDescription(id: string): string | undefined {
  const filePath = path.join(process.cwd(), "src/content/posts", `${id}.md`);
  const raw = fs.readFileSync(filePath, "utf-8");
  const body = raw.replace(/^---[\s\S]*?---\s*/, "");
  const firstPara = body
    .split(/\n\n/)[0]
    ?.replace(/[#*`\[\]()!<>]/g, "")
    .trim();
  if (firstPara && firstPara.length > 10) {
    return firstPara.length > 155 ? firstPara.slice(0, 152) + "..." : firstPara;
  }
}

const { post, prevNote, nextNote } = Astro.props;
const { Content } = await render(post);
const description = extractDescription(post.id);
const isNote = post.data.type === "note";
---

{isNote ? (
  <NoteLayout
    title={post.data.title}
    date={post.data.date}
    description={description}
    prevNote={prevNote}
    nextNote={nextNote}
  >
    <Content />
  </NoteLayout>
) : (
  <PostLayout
    title={post.data.title}
    date={post.data.date}
    description={description}
  >
    <Content />
  </PostLayout>
)}
