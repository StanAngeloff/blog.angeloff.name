---
import { getCollection, render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";
import NoteLayout from "../../layouts/NoteLayout.astro";
import fs from "node:fs";
import path from "node:path";

export async function getStaticPaths() {
  function toUrl(p: { id: string; data: { date: Date } }) {
    const d = p.data.date;
    return `/post/${d.getUTCFullYear()}/${String(d.getUTCMonth() + 1).padStart(2, "0")}/${String(d.getUTCDate()).padStart(2, "0")}/${p.id.slice(11)}/`;
  }

  const posts = await getCollection("posts");
  const sorted = posts.sort(
    (a, b) => a.data.date.getTime() - b.data.date.getTime(),
  );

  return sorted.map((post, idx) => {
    const date = post.data.date;
    const y = String(date.getUTCFullYear());
    const m = String(date.getUTCMonth() + 1).padStart(2, "0");
    const d = String(date.getUTCDate()).padStart(2, "0");
    const titleSlug = post.id.slice(11);

    const prev = idx > 0 ? sorted[idx - 1] : null;
    const next = idx < sorted.length - 1 ? sorted[idx + 1] : null;

    return {
      params: { slug: `${y}/${m}/${d}/${titleSlug}` },
      props: {
        post,
        prevPost: prev ? { url: toUrl(prev), title: prev.data.title } : null,
        nextPost: next ? { url: toUrl(next), title: next.data.title } : null,
      },
    };
  });
}

function extractDescription(id: string): string | undefined {
  const filePath = path.join(process.cwd(), "src/content/posts", `${id}.md`);
  const raw = fs.readFileSync(filePath, "utf-8");
  const body = raw.replace(/^---[\s\S]*?---\s*/, "");
  const firstPara = body
    .split(/\n\n/)[0]
    ?.replace(/[#*`\[\]()!<>]/g, "")
    .trim();
  if (firstPara && firstPara.length > 10) {
    return firstPara.length > 155 ? firstPara.slice(0, 152) + "..." : firstPara;
  }
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
const description = extractDescription(post.id);
const isNote = post.data.type === "note";
---

{
  isNote ? (
    <NoteLayout
      title={post.data.title}
      date={post.data.date}
      description={description}
      prevPost={prevPost}
      nextPost={nextPost}
    >
      <Content />
    </NoteLayout>
  ) : (
    <PostLayout
      title={post.data.title}
      date={post.data.date}
      description={description}
      prevPost={prevPost}
      nextPost={nextPost}
    >
      <Content />
    </PostLayout>
  )
}
