---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const allPosts = await getCollection("posts");
const sorted = allPosts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

function postUrl(post: (typeof sorted)[0]) {
  const date = post.data.date;
  const y = String(date.getUTCFullYear());
  const m = String(date.getUTCMonth() + 1).padStart(2, "0");
  const d = String(date.getUTCDate()).padStart(2, "0");
  return `/post/${y}/${m}/${d}/${post.id.slice(11)}/`;
}

type PostEntry = (typeof sorted)[0];
const byYear = new Map<number, PostEntry[]>();
for (const post of sorted) {
  const y = post.data.date.getUTCFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(post);
}
---

<BaseLayout activeNav="blog">
  <p class="lede">a collection of thoughts, rants &amp; research</p>
  {
    [...byYear.entries()].map(([year, posts]) => (
      <>
        <div class="year-rule">
          <span class="y">{year}</span>
          <span class="line" />
        </div>
        <ul class="post-list">
          {posts.map((post) => (
            <li class={post.data.type === "note" ? "note" : undefined}>
              <span class="date">
                {post.data.date.toLocaleDateString("en-US", {
                  month: "short",
                  day: "2-digit",
                })}
              </span>
              <span class="glyph">{post.data.type === "note" ? "¶" : "›"}</span>
              <span class="title">
                <a href={postUrl(post)}>{post.data.title}</a>
              </span>
            </li>
          ))}
        </ul>
      </>
    ))
  }
</BaseLayout>
