---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404: Page not found">
  <article class="fourohfour">
    <p class="glyph" aria-hidden="true">&empty;</p>
    <h1 class="label">404 &mdash; Page not found</h1>
    <p class="quote">
      &ldquo;This blog has been rewritten more times than some of the posts in it.
      A few URLs didn&rsquo;t survive the journey.&rdquo;
    </p>
    <p class="back"><a href="/">&larr; Back to the homepage</a></p>
  </article>
</BaseLayout>
